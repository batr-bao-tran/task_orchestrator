build --cxxopt=-std=c++20
build --host_cxxopt=-std=c++20

build --action_env=PATH
build --host_action_env=PATH

build:linux --linkopt=-fuse-ld=lld
build:linux --host_linkopt=-fuse-ld=lld

build:darwin --define=platform=darwin
build:darwin --macos_minimum_os=11.0

# Optional linker configs (Linux only).
build:gold --linkopt=-fuse-ld=gold
build:gold --host_linkopt=-fuse-ld=gold
build:bfd --linkopt=-fuse-ld=bfd
build:bfd --host_linkopt=-fuse-ld=bfd
build:lld --linkopt=-fuse-ld=lld
build:lld --host_linkopt=-fuse-ld=lld

build --cxxopt=-Wall --cxxopt=-Wextra
build --copt=-Wno-error=unused-parameter
build --cxxopt=-Wno-error=unused-parameter
build --host_cxxopt=-Wno-error=unused-parameter

# Test output
test --test_output=errors
test --test_summary=short
