# C++20 for task_orchestrator (coroutines, ranges, concepts)
build --cxxopt=-std=c++20
build --host_cxxopt=-std=c++20

# Ensure link step can find 'ld' (e.g. /usr/bin/ld from binutils). No manual install needed
# when a standard C++ toolchain is present; Bazel's sandbox may otherwise hide system PATH.
build --action_env=PATH=/usr/bin:/bin:/usr/local/bin

# Use gold linker (supports --start-lib; ld.bfd does not). Falls back to default if gold missing.
build --linkopt=-fuse-ld=gold
build --host_linkopt=-fuse-ld=gold

# Use GNU ld.bfd (may fail with "unrecognized option '--start-lib'").
build:bfd --linkopt=-fuse-ld=bfd
build:bfd --host_linkopt=-fuse-ld=bfd

# Prefer strict warnings in CI; optional for local dev
# build --cxxopt=-Wall --cxxopt=-Wextra

# Test output
test --test_output=errors
test --test_summary=short
